[project]
requires = ["nodejs-24"]
entrypoint = ".cozeproj/prototype/web/builder.html"

[dev]
build = ["mkdir", "-p", ".cozeproj/prototype/web"]
run = ["npx", "-y", "serve", ".cozeproj/prototype/web", "-p", "5000", "--no-clipboard"]

[deploy]
build = ["mkdir", "-p", ".cozeproj/prototype/web"]
run = ["npx", "-y", "serve", ".cozeproj/prototype/web", "-p", "5000", "--no-clipboard"]